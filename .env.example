# ============================================
# LogiTrack 환경 변수 템플릿
# ============================================
# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 입력하세요
# cp .env.example .env


# 데이터베이스 연결 정보
DATABASE_URL=postgresql://username:password@localhost:5432/logitrack

# Kakao API 키 (https://developers.kakao.com 에서 발급)
KAKAO_API_KEY=your_kakao_rest_api_key_here

# 비용 설정 (원)
FUEL_PRICE=1500
LABOR_COST_PER_HOUR=15000

# 데이터베이스 커넥션 풀 설정 (선택)
DB_POOL_MIN=1
DB_POOL_MAX=10

# 캐시 설정 (선택)
CACHE_TTL_HOURS=12

# API 타임아웃 설정 (초, 선택)
API_TIMEOUT_SEC=5